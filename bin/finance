#!/usr/bin/env bash
# Thin wrapper so `./bin/finance` works without installing the package.
# Once you `pip install -e .`, the `finance` command is on your PATH directly.
set -euo pipefail

# Resolve the repo root (parent of this script's bin/ dir).
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# Run the CLI module. PYTHONPATH ensures `src/` is importable without install.
PYTHONPATH="$REPO_ROOT/src${PYTHONPATH:+:$PYTHONPATH}" \
  exec python3 -m finance_advisor "$@"
